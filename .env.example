# Copy to `.env.local` for local dev. For GitHub Pages, set the same keys as
# repository secrets (Settings → Secrets and variables → Actions).

# EVM wallets (WalletConnect)
VITE_WALLETCONNECT_PROJECT_ID=

# Solana RPC (public endpoints or your provider URL)
# Local `npm run dev` proxies devnet to https://api.devnet.solana.com via /solana-devnet-rpc
# (official endpoint; browser cannot use it directly while TLS cert is expired).
VITE_SOLANA_RPC_URL=
VITE_SOLANA_DEVNET_RPC_URL=
VITE_SOLANA_MAINNET_RPC_URL=
VITE_SOLANA_TESTNET_RPC_URL=

# GRAI Solana cluster: devnet | testnet | mainnet-beta
VITE_GRAI_SOLANA_CLUSTER=devnet
VITE_GRAI_RPC_URL=
VITE_GRAI_DEVNET_RPC_URL=
VITE_GRAI_MAINNET_RPC_URL=
VITE_GRAI_TESTNET_RPC_URL=
VITE_GRAI_MINT=
VITE_GRAI_DEVNET_MINT=
VITE_GRAI_MAINNET_MINT=
VITE_GRAI_TESTNET_MINT=

# EVM GRAI token / protocol addresses
VITE_GRAI_ETHEREUM_TOKEN=
VITE_GRAI_ETHEREUM_PROTOCOL=
VITE_GRAI_BASE_TOKEN=
VITE_GRAI_BASE_PROTOCOL=
VITE_GRAI_ARBITRUM_TOKEN=
VITE_GRAI_ARBITRUM_PROTOCOL=
VITE_GRAI_SEPOLIA_TOKEN=
VITE_GRAI_SEPOLIA_PROTOCOL=
VITE_GRAI_BASE_SEPOLIA_TOKEN=
VITE_GRAI_BASE_SEPOLIA_PROTOCOL=

# Backtest API (hosted separately; optional for GRAI pages)
VITE_BACKTEST_API_URL=

# Boss API (grinder live table). Local dev proxies `/api` → Boss (`BOSS_API_TARGET`).
# Docker dev default: http://boss-backend-dev:8000
BOSS_API_TARGET=
# Dev `/boss-remote` proxy: comma-separated hosts allowed to skip TLS verification.
# Subdomains are included (e.g. grinder-1.boss.localhost).
BOSS_REMOTE_INSECURE_TLS_HOSTS=boss.localhost
VITE_BOSS_API_URL=/api
VITE_BOSS_API_KEY=
VITE_BOSS_API_AUTH_HEADER=x-boss-key

# Link in header back to main GrindURUS site
VITE_MAIN_APP_URL=
